<Window x:Class="WindowsAppCleaner.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Windows 应用清理器 - 设置" Width="780" Height="610" MinWidth="700" MinHeight="540"
        WindowStartupLocation="CenterScreen" Background="#FFF5F8FA">
    <Window.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ui:ThemesDictionary Theme="Light" /><ui:ControlsDictionary /></ResourceDictionary.MergedDictionaries></ResourceDictionary></Window.Resources>
    <Grid Margin="28,22">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="应用清理器设置" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
            <TextBlock Text="快捷键、启动行为和长期保留规则" Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}" />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,20,0,16" Padding="20" Background="White" CornerRadius="16" BorderBrush="#15000000" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="150" /><ColumnDefinition Width="220" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <TextBlock Text="全局快捷键" VerticalAlignment="Center" />
                <TextBox x:Name="HotkeyBox" Grid.Column="1" Height="34" VerticalContentAlignment="Center" />
                <TextBlock Grid.Column="2" Text="例如 F4 / Ctrl+Alt+K" Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
                <TextBlock Grid.Row="1" Text="默认清理范围" Margin="0,16,0,0" VerticalAlignment="Center" />
                <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,12,0,0">
                    <RadioButton x:Name="BothMode" Content="前台 + 后台" GroupName="mode" Margin="0,0,20,0" />
                    <RadioButton x:Name="ForegroundMode" Content="仅前台" GroupName="mode" />
                </StackPanel>
                <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,16,0,0">
                    <CheckBox x:Name="AutostartCheck" Content="开机启动" Margin="0,0,22,0" />
                    <CheckBox x:Name="MinimizedCheck" Content="启动时保持收起" Margin="0,0,22,0" />
                    <CheckBox x:Name="FullscreenCheck" Content="全屏时隐藏悬浮球" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="54" /><ColumnDefinition /></Grid.ColumnDefinitions>
            <Border Padding="16" Background="White" CornerRadius="16" BorderBrush="#15000000" BorderThickness="1">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <TextBlock Text="当前应用" FontWeight="SemiBold" FontSize="15" />
                    <ListBox x:Name="CurrentAppsList" Grid.Row="1" Margin="0,12,0,0" SelectionMode="Extended" DisplayMemberPath="ProcessName" BorderThickness="0" />
                </Grid>
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <Button Content="›" Width="38" Height="38" FontSize="22" Click="OnAddAllow" ToolTip="加入保留名单" />
                <Button Content="‹" Width="38" Height="38" FontSize="22" Margin="0,10,0,0" Click="OnRemoveAllow" ToolTip="移出保留名单" />
            </StackPanel>
            <Border Grid.Column="2" Padding="16" Background="White" CornerRadius="16" BorderBrush="#15000000" BorderThickness="1">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <TextBlock Text="长期保留" FontWeight="SemiBold" FontSize="15" />
                    <ListBox x:Name="AllowlistList" Grid.Row="1" Margin="0,12,0,0" SelectionMode="Extended" BorderThickness="0" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="0,18,0,0">
            <TextBlock x:Name="VersionText" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Width="88" Height="38" Click="OnCancel" />
                <Button Content="保存设置" Width="108" Height="38" Margin="10,0,0,0" Background="#0D9488" Foreground="White" Click="OnSave" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
